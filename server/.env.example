# ── MongoDB ─────────────────────────────────────────────
# Paste your MongoDB Atlas connection string here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/wildexplore?retryWrites=true&w=majority

# ── Server ──────────────────────────────────────────────
PORT=5000

# ── CORS origin (your deployed frontend URL) ────────────
# For local dev use: http://localhost:5173
# For production use your Vercel / Netlify URL
CLIENT_ORIGIN=http://localhost:5173
